# Copy to .env (docker compose auto-loads it) or export these in your shell.
# These override the defaults baked into docker-compose.yml.

# --- normal operation ---
WORKERS=10
BATCH_SIZE=100
RATE_RPS=100
RATE_BURST=200
RATE_IDLE_TTL_SEC=600
USE_ROLLUPS=true
ROLLUP_REFRESH_SEC=60
REQUIRE_USER_ID_FOR_CONVERSION=false

# --- for load/throughput benchmarking (raise the limit so k6 isn't throttled) ---
# RATE_RPS=100000
# RATE_BURST=200000
