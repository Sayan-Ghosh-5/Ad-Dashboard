# Benchmarking profile. Use it explicitly:
#   docker compose --env-file .env.bench up -d --build --force-recreate
#
# Raises the rate limit so k6 (single IP) isn't throttled, and gives the
# worker pool more headroom.

RATE_RPS=1000000
RATE_BURST=2000000
WORKERS=16
BATCH_SIZE=200
USE_ROLLUPS=true
ROLLUP_REFRESH_SEC=60
